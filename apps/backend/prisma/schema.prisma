generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  admin
  editor
  viewer
}

model User {
  id           String   @id @default(uuid())
  username     String
  email        String   @unique
  passwordHash String
  type         UserType
  comments     Comment[] @relation("UserComments")
}

model Kingdom {
  id          String    @id @default(uuid())
  name        String
  population  Int?
  description String?
  dateInGame  DateTime?

  cities   City[]
  places   Place[]
  comments Comment[]
  persons  PersonOfInterest[]
  position Position?
}

model City {
  id          String    @id @default(uuid())
  name        String
  description String?
  kingdomId   String?

  kingdom  Kingdom? @relation(fields: [kingdomId], references: [id])
  places   Place[]
  comments Comment[]
  persons  PersonOfInterest[]
  position Position?
}

model Place {
  id          String    @id @default(uuid())
  name        String
  description String?
  kingdomId   String?
  cityId      String?

  kingdom  Kingdom? @relation(fields: [kingdomId], references: [id])
  city     City?    @relation(fields: [cityId], references: [id])
  comments Comment[]
  persons  PersonOfInterest[]
  position Position?
}

model PersonOfInterest {
  id          String    @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  membership  String?
  languages   String[]
  STR         Int
  DEX         Int
  CON         Int
  INT         Int
  WIS         Int
  CHA         Int
  kingdomId   String?
  cityId      String?
  placeId     String?

  kingdom  Kingdom? @relation(fields: [kingdomId], references: [id])
  city     City?    @relation(fields: [cityId], references: [id])
  place    Place?   @relation(fields: [placeId], references: [id])
  comments Comment[]
  position Position?
}

model Comment {
  id                 String   @id @default(uuid())
  description        String
  dateInGame         DateTime?
  kingdomId          String?
  cityId             String?
  placeId            String?
  personOfInterestId String?
  authorId           String?

  kingdom          Kingdom?          @relation(fields: [kingdomId], references: [id])
  city             City?             @relation(fields: [cityId], references: [id])
  place            Place?            @relation(fields: [placeId], references: [id])
  personOfInterest PersonOfInterest? @relation(fields: [personOfInterestId], references: [id])
  author           User?             @relation("UserComments", fields: [authorId], references: [id])
}

model Position {
  id                 String   @id @default(uuid())
  x                  Float
  y                  Float
  kingdomId          String? @unique
  cityId             String? @unique
  placeId            String? @unique
  personOfInterestId String? @unique

  kingdom          Kingdom?          @relation(fields: [kingdomId], references: [id])
  city             City?             @relation(fields: [cityId], references: [id])
  place            Place?            @relation(fields: [placeId], references: [id])
  personOfInterest PersonOfInterest? @relation(fields: [personOfInterestId], references: [id])
}

