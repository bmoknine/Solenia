{
  "name": "backend",
  "version": "1.0.0",
  "description": "API Fastify + Prisma pour la carte interactive.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --import tsx --require tsconfig-paths/register --watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:sync": "node scripts/run-migrate.mjs && prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "node scripts/run-migrate.mjs",
    "prisma:push": "prisma db push",
    "prisma:seed": "prisma db seed",
    "check-orphans": "tsx scripts/check-orphans.ts",
    "clean-orphans": "tsx scripts/clean-orphans.ts",
    "wipe-data": "tsx scripts/wipe-all-except-users.ts",
    "db:backup": "mkdir -p backups && (set -a && . ./.env 2>/dev/null; set +a; pg_dump \"$DATABASE_URL\" -F p -f \"backups/solenia_$(date +%Y%m%d_%H%M%S).sql\" && echo \"Sauvegarde créée dans backups/\")"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^8.4.2",
    "@fastify/jwt": "^7.2.0",
    "@fastify/sensible": "^5.6.0",
    "@prisma/client": "^6.19.1",
    "argon2": "^0.44.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "fastify-type-provider-zod": "^2.0.0",
    "prisma": "^6.19.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.8.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
